# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=8787
# Render injects PORT automatically. On Render, set PORT=10000 in render.yaml
# and let the platform override it at runtime if needed.
BACKEND_BASE_URL=http://localhost:8787
TRUST_PROXY=false
LOG_LEVEL=debug
NODE_OPTIONS=--max-old-space-size=512

# Database (required in staging/production)
# Local Postgres example:
# POSTGRES_URL=postgres://postgres:postgres@localhost:5432/debt_destroyer?sslmode=disable
# Neon pooled example for Render:
# POSTGRES_URL=postgresql://USER:PASSWORD@EP-XXXX-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/debt_destroyer?sslmode=disable
POSTGRES_POOL_MAX=10
POSTGRES_POOL_MIN=0
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONNECTION_TIMEOUT_MS=10000
POSTGRES_MAX_LIFETIME_SECONDS=300

# Redis (required in staging/production)
# Render Key Value example: redis://red-xxxxxxxxxxxxxxxxxxxx:6379
# Upstash example: rediss://default:password@region-name.upstash.io:6379
REDIS_URL=redis://localhost:6379

# Auth (JWT_SECRET required in staging/production; ACCESS/REFRESH can override separately)
JWT_SECRET=replace_me_jwt_secret
JWT_ACCESS_SECRET=replace_me_access_override
JWT_REFRESH_SECRET=replace_me_refresh_override
JWT_ISSUER=debt-destroyer-backend
JWT_AUDIENCE=debt-destroyer-mobile
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=30

# Gemini (required in staging/production)
GEMINI_API_KEY=replace_me_gemini
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_VERSION=v1beta
GEMINI_TIMEOUT_MS=15000

# Quota
FREE_SCAN_LIMIT=5

# Google Play / Android (required in staging/production)
GOOGLE_PLAY_PACKAGE_NAME=com.debtdestroyer.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace_me"}
PLAY_INTEGRITY_CLOUD_PROJECT_NUMBER=123456789
PLAY_INTEGRITY_PACKAGE_NAME=com.debtdestroyer.app
PREMIUM_PRODUCT_ID=premium
PREMIUM_MONTHLY_BASE_PLAN_ID=monthly
PREMIUM_YEARLY_BASE_PLAN_ID=yearly

# Rate limits (requests per minute)
RATE_LIMIT_BOOTSTRAP_CHALLENGE_PER_MINUTE=20
RATE_LIMIT_BOOTSTRAP_VERIFY_PER_MINUTE=20
RATE_LIMIT_TOKEN_REFRESH_PER_MINUTE=20
RATE_LIMIT_BILLING_VERIFY_PER_MINUTE=20
RATE_LIMIT_BILLING_RESTORE_PER_MINUTE=10
RATE_LIMIT_EXTRACTION_INSTALL_PER_MINUTE=20
RATE_LIMIT_EXTRACTION_IP_PER_MINUTE=60

# Attestation debug mode (development/test only)
# Development/test only. Keep false in staging/production.
ALLOW_DEBUG_ATTESTATION=true
DEBUG_ATTESTATION_SECRET=replace_me_debug_only

# Maintenance
ENABLE_CLEANUP_JOBS=false
CLEANUP_INTERVAL_MINUTES=60
